/*
  Security headers su tutto il sito
*/
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Cache 1 anno per asset condivisi (immagini, video, font)
/shared/images/*
  Cache-Control: public, max-age=31536000, immutable
/shared/videos/*
  Cache-Control: public, max-age=31536000, immutable
/shared/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Cache 1 anno per CSS e JS delle 2 demo ufficiali (immutabili al deploy)
/v1-warm/style.css
  Cache-Control: public, max-age=31536000, immutable
/v1-warm/script.js
  Cache-Control: public, max-age=31536000, immutable
/v3-tech/style.css
  Cache-Control: public, max-age=31536000, immutable
/v3-tech/script.js
  Cache-Control: public, max-age=31536000, immutable

# Tour 360°
/tour-360/tour.css
  Cache-Control: public, max-age=31536000, immutable
/tour-360/tour.js
  Cache-Control: public, max-age=31536000, immutable
/tour-360/themes.css
  Cache-Control: public, max-age=31536000, immutable

# Cache 5 minuti per HTML (revalidate veloce ad ogni deploy)
/*.html
  Cache-Control: public, max-age=300, must-revalidate
